# ═══════════════════════════════════════════════════════════════════════════════
# BWGA Intelligence AI - Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# 
# This is a CLEAN CONFIGURATION - no API keys pre-configured
# Add your API keys when you're ready to enable AI features
#
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Server Configuration ──────────────────────────────────────────────────────
PORT=3004
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── Optional AI Provider Keys (add when ready) ────────────────────────────────
# Once you add an API key below, the system will automatically use it
# 
# OpenAI GPT-4: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your-key-here
#
# Groq (free tier): https://console.groq.com
# GROQ_API_KEY=your-key-here
#
# Together.ai (free tier): https://api.together.xyz
# TOGETHER_API_KEY=your-key-here

# ─── Feature Flags ─────────────────────────────────────────────────────────────
VITE_USE_REAL_AI=true
VITE_USE_REAL_DATA=true
VITE_USE_REAL_BACKEND=true
VITE_SHOW_DEMO_INDICATORS=false
VITE_ENABLE_SELF_LEARNING=true

# ─── External Data Sources ────────────────────────────────────────────────────
VITE_ENABLE_EXTERNAL_DATA=true
NODE_ENV=development

# Frontend URL (for CORS) - Update for production
FRONTEND_URL=http://localhost:5173

# ============================================
# Feature Flags (Vite-compatible VITE_* prefix)
# ============================================
VITE_USE_REAL_AI=true
VITE_USE_REAL_DATA=true
VITE_USE_REAL_BACKEND=true
VITE_SHOW_DEMO_INDICATORS=false
VITE_ENABLE_SELF_LEARNING=true

# Enable external data sources (World Bank, Numbeo, OpenCorporates)
VITE_ENABLE_EXTERNAL_DATA=true
VITE_DEBUG_RESEARCH=true

# ============================================
# Autonomous Mode
# ============================================
AUTONOMOUS_MODE_DEFAULT=true
AUTO_ACT_ENABLED=true

# ============================================
# Optional: Additional Services
# ============================================
# ANTHROPIC_API_KEY=your-anthropic-key-here
# SERPER_API_KEY=your-serper-key-here

# ============================================
# Entity Intelligence Pipeline (Tier 1+2)
# ============================================
# Tavily — AI-optimized search (free tier: 1000 searches/mo)
# Get a key at: https://tavily.com
# VITE_TAVILY_API_KEY=your-tavily-api-key-here

# Brave Search — Independent non-Google web index (free tier: 2000 queries/mo)
# Get a key at: https://brave.com/search/api/
# VITE_BRAVE_SEARCH_API_KEY=your-brave-search-api-key-here

# GLEIF — Legal Entity Identifiers (FREE, no key required)
# OpenSanctions — Sanctions/PEP screening (FREE, no key required for basic)
# V-Dem — Academic governance data (embedded, no key required)
